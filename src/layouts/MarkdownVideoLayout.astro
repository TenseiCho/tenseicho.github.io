---
import BaseLayout from './Layout.astro';
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>
    <h2>{frontmatter.title}</h2>
    <img src={frontmatter.image.url} alt={frontmatter.image.alt} />
    <p>{frontmatter.description}</p>
    <div class="social-links">
        <ul>
            <li><strong>YouTube:</strong> <a href={frontmatter.youtubeLink} target="_blank">Watch on YouTube</a></li>
            {frontmatter.socialmediaLink && (
                <li><strong>X:</strong> <a href={frontmatter.socialmediaLink} target="_blank" class="social-link">Follow on X</a></li>
            )}
        </ul>
    </div>
    <slot />
</BaseLayout>

<style>
    .social-links {
        margin: 1rem 0;
    }
    .social-links ul {
        list-style: none;
        padding: 0;
    }
    .social-links li {
        margin: 0.5rem 0;
    }
    .social-links a {
        color: var(--text-link);
        text-decoration: none;
        cursor: pointer;
    }
    .social-links a:hover {
        text-decoration: underline;
    }
    .social-link {
        display: inline-block;
        pointer-events: auto;
    }
</style> 