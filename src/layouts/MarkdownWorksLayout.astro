---
import BaseLayout from './Layout.astro';
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>
    <div class="gif">
        <img width="300" height="259" alt="RaccoonLaptopGif" src="/laptop.webp"/>
    </div>
    <h2>{frontmatter.title}</h2>
    <slot />
    <ul class="badge__list">
        <li><span class="badge badge--item">PLATFORM</span>{frontmatter.platform}</li>
        <li><span class="badge badge--item">STACK</span>{frontmatter.stack}</li>
        <li><span class="badge badge--item">WEBSITE</span><a class="badge__link" href={frontmatter.website} target="_blank">{frontmatter.website}</a></li>
        <li><span class="badge badge--item">GITHUB</span><a class="badge__link" href={frontmatter.github} target="_blank">{frontmatter.github}</a></li>
    </ul>
    <div class="center">
        <div class="project-image-container">
            <img class="project-image" src={frontmatter.worksImage1.url} alt={frontmatter.worksImage1.alt} />
        </div>
        <div class="project-image-container">
            <img class="project-image" src={frontmatter.worksImage2.url} alt={frontmatter.worksImage2.alt} />
        </div>
    </div>
</BaseLayout>

<style>
    .project-image-container {
        width: 500px;
        max-width: 100%;
        margin: 1rem auto;
    }
    .project-image {
        width: 100%;
        height: auto;
        border-radius: 8px;
    }
</style>

