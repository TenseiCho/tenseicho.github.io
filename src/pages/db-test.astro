---
import Layout from '../layouts/Layout.astro';
const pageTitle = "Database Connection Test";
---

<Layout pageTitle={pageTitle}>
    <div class="container">
        <h2>Database Connection Test</h2>
        <div id="status" class="status">Checking connection...</div>
        <button id="testButton" class="btn">Test Connection</button>
        <div id="details" class="details"></div>
    </div>
</Layout>

<style>
    .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        text-align: center;
    }

    .status {
        margin: 20px 0;
        padding: 15px;
        border-radius: 5px;
        font-weight: bold;
    }

    .success {
        background-color: #78c2ad33;
        color: #78c2ad;
    }

    .error {
        background-color: #ff634733;
        color: #ff6347;
    }

    .details {
        margin-top: 20px;
        text-align: left;
        font-family: monospace;
        white-space: pre-wrap;
    }

    .btn {
        margin: 10px 0;
    }
</style>

<script>
    const statusDiv = document.getElementById('status');
    const detailsDiv = document.getElementById('details');
    const testButton = document.getElementById('testButton');

    async function testConnection() {
        statusDiv.className = 'status';
        statusDiv.textContent = 'Testing connection...';
        detailsDiv.textContent = '';

        try {
            const response = await fetch('/api/test-db');
            const data = await response.json();

            if (data.success) {
                statusDiv.className = 'status success';
                statusDiv.textContent = 'Connection Successful!';
                detailsDiv.textContent = `Timestamp: ${data.timestamp}\nMessage: ${data.message}`;
            } else {
                statusDiv.className = 'status error';
                statusDiv.textContent = 'Connection Failed';
                detailsDiv.textContent = `Error: ${data.error}\nDetails: ${JSON.stringify(data.details, null, 2)}`;
            }
        } catch (error) {
            statusDiv.className = 'status error';
            statusDiv.textContent = 'Connection Failed';
            detailsDiv.textContent = `Error: ${error.message}`;
        }
    }

    testButton.addEventListener('click', testConnection);
    // Test connection on page load
    testConnection();
</script> 