---
import { Image } from 'astro:assets';

interface Props {
    url: string;
    image: ImageMetadata;
    title: string;
    body: string;
    isAboveFold?: boolean;
}

const { url, image, title, body, isAboveFold = false } = Astro.props;
---
<li class="card">
    <a class="card__link" href={url}>
        <div class="center">
            <Image 
                class="card__img" 
                src={image} 
                width={300}  // Increased from 180
                height={169}  // Increased from 101 to maintain aspect ratio
                alt={`Image for ${title}`}
                loading={isAboveFold ? "eager" : "lazy"}
            />
        </div>
        <h3 class="card__title">
            {title}
        </h3>
        <p class="card__txt">
            {body}
        </p>
    </a>
</li>

