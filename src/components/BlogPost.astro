---
interface Props {
    url: string;
    title: string;
    pubDate: string;
}

const { url, title, pubDate } = Astro.props;
---
<li class="blog-post">
    <div class="blog-post__content">
        <a href={url} class="blog-post__title">{title}</a>
        <p class="blog-post__date">{pubDate}</p>
    </div>
</li>

<style>
    .blog-post {
        margin-bottom: 2rem;
    }
    .blog-post__content {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }
    .blog-post__title {
        font-size: 1.2rem;
        margin-right: 1rem;
    }
    .blog-post__date {
        font-size: 0.9rem;
        color: #666;
        white-space: nowrap;
    }
</style>